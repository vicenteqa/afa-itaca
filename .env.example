SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Opcional. Si s'informa, tots els missatges del formulari s'envien a aquesta adreca.
# Si no s'informa, els missatges s'envien a la comissio seleccionada al formulari.
# CONTACT_EMAIL=

# Opcional. Mostra codis d'error SMTP segurs a la resposta de /api/contact per depurar.
CONTACT_DEBUG_ERRORS=false

# Opcional. Activa la seccio d'Instagram de la home amb: 1, true, yes o on.
SHOW_HOME_INSTAGRAM_FEED=false
