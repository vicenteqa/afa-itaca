---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const comissions = await getCollection('comissions');
	return comissions.map((comissio) => ({
		params: { slug: comissio.id },
		props: comissio,
	}));
}

const comissio = Astro.props;
const { Content } = await render(comissio);
---

<!doctype html>
<html lang="ca">
	<head>
		<BaseHead title={`${comissio.data.title} | ${SITE_TITLE}`} description={comissio.data.description} />
	</head>
	<body>
		<Header />
		<main>
			<article class="prose">
				<div class="title">
					<h1>{comissio.data.title}</h1>
					<p class="description">{comissio.data.description}</p>
					<hr />
				</div>
				<Content />
				<div class="back-link">
					<a href="/">← Tornar a l'Inici</a>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.title {
		margin-bottom: 2em;
		padding: 1em 0;
		text-align: center;
		line-height: 1.2;
	}
	.title h1 {
		margin: 0 0 0.5rem 0;
		color: var(--accent-dark); /* Azul oscuro de la marca */
		font-size: 3rem;
	}
	.description {
		margin-bottom: 0;
		color: var(--text-light);
		font-size: 1.2rem;
	}
	.back-link {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid #eee;
	}
	.back-link a {
		color: var(--accent-dark);
		text-decoration: none;
		font-weight: 600;
	}
	.back-link a:hover {
		color: var(--accent);
		text-decoration: underline;
	}
</style>
