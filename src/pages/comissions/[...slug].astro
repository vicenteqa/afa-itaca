---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ImageCarousel from '../../components/ImageCarousel.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const comissions = await getCollection('comissions');
	return comissions.map((comissio) => ({
		params: { slug: comissio.id },
		props: comissio,
	}));
}

const comissio = Astro.props;
const { Content } = await render(comissio);
---

<!doctype html>
<html lang="ca">
	<head>
		<BaseHead title={`${comissio.data.title} | ${SITE_TITLE}`} description={comissio.data.description} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>{comissio.data.title}</h1>
				{comissio.data.description && <p class="description">{comissio.data.description}</p>}
			</section>

			<article class="prose">
				<div class="content">
					<Content />
					{
						comissio.data.carouselImages && comissio.data.carouselImages.length > 0 && (
							<ImageCarousel
								images={comissio.data.carouselImages}
								label={comissio.data.carouselLabel ?? `Carrusel d'imatges de ${comissio.data.title}`}
							/>
						)
					}
				</div>
				<div class="back-link">
					<a href="/">← Tornar a l'Inici</a>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
	}
	.prose {
		width: 100%;
		max-width: none;
	}
	.content {
		max-width: 960px;
		margin: 0 auto;
		padding: 3rem 1.5rem;
	}
	@media (max-width: 720px) {
		.content {
			padding: 1.5rem 1rem;
		}
	}
	.back-link {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 2rem 3rem 2rem;
	}
	.back-link a {
		color: var(--accent-dark);
		text-decoration: none;
		font-weight: 600;
	}
	.back-link a:hover {
		color: var(--accent);
		text-decoration: underline;
	}
</style>
