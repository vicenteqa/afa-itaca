---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const latestNews = (await getCollection('noticies'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="ca">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Benvinguts a l'AFA de l'escola Ítaca!</h1>
				<p class="description">{SITE_DESCRIPTION}</p>
			</section>
			<InstagramFeed />

			<section class="quick-links">
				<h2>Accés ràpid</h2>
				<div class="links-grid">
					<a href="/noticies" class="link-card">
						<h3>Notícies</h3>
						<p>Estigues al dia de tot el que passa a l'escola</p>
					</a>
					<a href="/lafa" class="link-card">
						<h3>Sobre l'AFA</h3>
						<p>Coneix qui som i què fem</p>
					</a>
					<a href="/menu-del-mes" class="link-card highlight">
						<h3>🍽️ Menú del Mes</h3>
						<p>Consulta el menú escolar actualitzat</p>
					</a>
				</div>
			</section>

			<section class="latest-news">
				<h2>Últimes notícies</h2>
				<div class="news-grid">
					{latestNews.map((post) => (
						<article class="news-card">
							<a href={`/noticies/${post.id}/`}>
								<h3>{post.data.title}</h3>
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<p class="description">{post.data.description}</p>
							</a>
						</article>
					))}
				</div>
				<div class="view-all">
					<a href="/noticies" class="btn">Veure totes les notícies →</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
	}

	main section:not(.hero) {
		max-width: 1200px;
		margin: 0 auto;
		padding: 3rem 2rem;
	}

	section h2 {
		font-size: 2rem;
		color: rgb(var(--gray-dark));
		margin-bottom: 2rem;
		text-align: center;
	}

	.links-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2rem;
		margin-top: 1rem;
	}

	.link-card {
		background: white;
		border: 2px solid var(--gray-light);
		border-top: 6px solid var(--accent); /* Borde superior de color */
		border-radius: 16px;
		padding: 2.5rem 2rem;
		text-decoration: none;
		color: var(--gray-dark);
		transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	/* Colores diferentes para cada tarjeta */
	.link-card:nth-child(2) {
		border-top-color: var(--tertiary);
	}
	
	.link-card.highlight {
		border-top-color: var(--secondary);
		background: var(--nav-hover-bg);
		border-color: var(--accent-pastel);
	}

	.link-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 12px 25px rgba(1, 143, 210, 0.12);
		border-color: var(--accent-pastel);
	}

	.link-card h3 {
		margin: 0 0 0.75rem 0;
		color: var(--accent-dark);
		font-size: 1.6rem;
		font-family: 'Fredoka', sans-serif;
	}

	.link-card:nth-child(2) h3 {
		color: #8e74a5; /* Tono lila para Sobre l'AFA */
	}

	.link-card.highlight h3 {
		color: #d67a91; /* Tono rosado para Menú */
	}

	.link-card p {
		margin: 0;
		color: var(--gray);
		font-size: 1.1rem;
		line-height: 1.4;
	}

	.news-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
		margin-bottom: 2rem;
	}

	.news-card {
		background: white;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		overflow: hidden;
		box-shadow: var(--box-shadow);
		transition: transform 0.2s ease;
	}

	.news-card:hover {
		transform: translateY(-4px);
	}

	.news-card a {
		display: block;
		padding: 1.5rem;
		text-decoration: none;
		color: rgb(var(--gray-dark));
	}

	.news-card h3 {
		margin: 0 0 0.5rem 0;
		color: rgb(var(--accent));
		font-size: 1.3rem;
	}

	.date {
		margin: 0 0 0.75rem 0;
		color: rgb(var(--gray-light));
		font-size: 0.9rem;
	}

	.description {
		margin: 0;
		color: rgb(var(--gray));
		line-height: 1.5;
	}

	.view-all {
		text-align: center;
	}

	.btn {
		display: inline-block;
		padding: 0.75rem 2rem;
		background: rgb(var(--accent));
		color: white;
		text-decoration: none;
		border-radius: 4px;
		font-weight: 500;
		transition: opacity 0.2s ease;
	}

	.btn:hover {
		opacity: 0.9;
	}

	@media (max-width: 720px) {
		.hero h1 {
			font-size: 2rem;
		}

		.hero-subtitle {
			font-size: 1.2rem;
		}

		.links-grid,
		.news-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
