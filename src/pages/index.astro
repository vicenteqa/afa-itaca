---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const latestNews = (await getCollection('noticies'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="ca">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Benvinguts a l'AFA de l'escola Ítaca!</h1>
				<p class="description">{SITE_DESCRIPTION}</p>
			</section>
			<InstagramFeed />

			<section class="quick-links">
				<h2>Accés ràpid</h2>
				<div class="links-grid">
					<a href="https://www.afaitaca.org/wp-content/uploads/menjador.jpg" target="_blank" rel="noopener noreferrer" class="link-card highlight" id="menu-link">
						<h3>🍽️ Menú del Mes</h3>
						<p>Consulta el menú escolar actualitzat</p>
					</a>
					<a href="https://www.imet.cat/doc/doc_31402494.pdf" target="_blank" rel="noopener noreferrer" class="link-card">
						<h3>📅 Calendari Escolar</h3>
						<p>Consulta el calendari de curs actual</p>
					</a>
					<a href="/lafa" class="link-card">
						<h3>Sobre l'AFA</h3>
						<p>Coneix qui som i què fem</p>
					</a>
				</div>
			</section>

			<section class="latest-news">
				<h2>Últimes notícies</h2>
				<div class="news-grid">
					{latestNews.map((post) => (
						<article class="news-card">
							<a href={`/noticies/${post.id}/`}>
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<h3>{post.data.title}</h3>
								<p class="news-description">
									{post.data.description.length > 140 
										? post.data.description.substring(0, 140) + '...' 
										: post.data.description}
								</p>
							</a>
						</article>
					))}
				</div>
				<div class="view-all">
					<a href="/noticies" class="btn">Veure totes les notícies →</a>
				</div>
			</section>
		</main>
		<Footer />
		<script>
			// Actualizar el link del menú con un timestamp fresco al hacer clic
			const menuLink = document.getElementById('menu-link') as HTMLAnchorElement;
			if (menuLink) {
				menuLink.addEventListener('click', (e) => {
					const timestamp = Date.now();
					menuLink.href = `https://www.afaitaca.org/wp-content/uploads/menjador.jpg?v=${timestamp}`;
				});
			}
		</script>
	</body>
</html>

<style>
	main {
		width: 100%;
	}

	main section:not(.hero) {
		max-width: 1200px;
		margin: 0 auto;
		padding: 3rem 1.5rem;
	}

	@media (max-width: 720px) {
		main section:not(.hero) {
			padding: 2rem 1rem;
		}
	}

	section h2 {
		font-size: 2rem;
		color: rgb(var(--gray-dark));
		margin-bottom: 2rem;
		text-align: center;
	}

	.links-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		margin-top: 1rem;
	}

	.link-card {
		background: white;
		border: 2px solid var(--gray-light);
		border-top: 6px solid var(--accent-dark); /* Color por defecto */
		border-radius: 16px;
		padding: 2.5rem 2rem;
		text-decoration: none;
		color: var(--gray-dark);
		transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	/* Colores de acento solo en el borde superior */
	.link-card.highlight {
		border-top-color: #a7c957; /* Verde para el Menú */
		background: white;
	}

	.link-card:nth-child(2) {
		border-top-color: var(--accent-dark); /* Azul para Notícies */
	}
	
	.link-card:nth-child(3) {
		border-top-color: #8e74a5; /* Lila para L'AFA */
	}

	.link-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 12px 25px rgba(0, 0, 0, 0.08);
		border-color: var(--accent-pastel); /* Un toque de color al hover en todo el borde */
	}

	.link-card h3 {
		margin: 0 0 0.75rem 0;
		color: var(--accent-dark);
		font-size: 1.6rem;
		font-family: 'Fredoka', sans-serif;
	}

	.link-card.highlight h3 {
		color: #a7c957;
	}

	.link-card:nth-child(2) h3 {
		color: var(--accent-dark);
	}

	.link-card:nth-child(3) h3 {
		color: #8e74a5;
	}

	.link-card p {
		margin: 0;
		color: var(--gray);
		font-size: 1.1rem;
		line-height: 1.4;
	}

	.news-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2.5rem;
		margin-bottom: 3rem;
	}

	.news-card {
		background: white;
		border: 2px solid var(--gray-light);
		border-top: 6px solid var(--accent-pastel); /* Azul clarito consistente */
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
		transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		display: flex;
		flex-direction: column;
		text-align: center;
	}

	.news-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 12px 25px rgba(0, 0, 0, 0.08);
		border-color: var(--accent-pastel);
	}

	.news-card a {
		display: block;
		padding: 2.5rem 2rem;
		text-decoration: none;
		color: var(--gray-dark);
		height: 100%;
	}

	.news-card h3 {
		margin: 0 0 1rem 0;
		color: var(--accent-dark);
		font-size: 1.4rem;
		font-family: 'Fredoka', sans-serif;
		line-height: 1.3;
	}

	.date {
		margin: 0 0 0.75rem 0;
		color: var(--gray);
		font-size: 0.9rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.news-description {
		margin: 0;
		color: var(--gray);
		line-height: 1.6;
		font-size: 1rem;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		height: 4.8em; /* Altura fija para asegurar que todas las tarjetas midan lo mismo */
	}

	.view-all {
		text-align: center;
	}

	.btn {
		display: inline-block;
		padding: 0.75rem 2rem;
		background: rgb(var(--accent));
		color: white;
		text-decoration: none;
		border-radius: 4px;
		font-weight: 500;
		transition: opacity 0.2s ease;
	}

	.btn:hover {
		opacity: 0.9;
	}

	@media (max-width: 720px) {
		.hero h1 {
			font-size: 2rem;
		}

		.hero-subtitle {
			font-size: 1.2rem;
		}

		.links-grid,
		.news-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
