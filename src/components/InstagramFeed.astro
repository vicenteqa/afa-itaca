---
const BEHOLD_URL = 'https://feeds.behold.so/a0X4l9ExTxkgGPtAK3u6';

let posts = [];
let username = 'afaitaca';

try {
  const response = await fetch(BEHOLD_URL);
  const data = await response.json();
  posts = data.posts.slice(0, 3);
  if (data.username) {
    username = data.username;
  }
} catch (error) {
  console.error('Error fetching Instagram feed:', error);
}
---

{posts.length > 0 && (
  <div class="instagram-animated-wrapper">
    <a href={`https://www.instagram.com/${username}`} target="_blank" rel="noopener noreferrer" class="ig-user-link">
      Darreres publicacions a Instagram
    </a>
    <div class="photo-flex-row">
      {posts.map((post) => (
        <a href={post.permalink} target="_blank" rel="noopener noreferrer" class="photo-link-animated">
          <div class="image-container">
            <img src={post.sizes.small.mediaUrl} alt="Instagram" />
            <div class="ig-overlay">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ig-icon"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
)}

<style>
  .instagram-animated-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 2.5rem 0;
    margin: 0 auto;
    max-width: 800px;
    width: 100%;
    text-align: center;
  }

  .ig-user-link {
    font-size: 0.85rem;
    color: #666;
    text-decoration: none;
    font-weight: 700;
    transition: color 0.2s;
    letter-spacing: 0.1em;
  }

  .ig-user-link:hover {
    color: #bc1888;
  }

  .photo-flex-row {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    width: 100%;
    padding: 0 1rem;
  }

  .photo-link-animated {
    flex: 0 1 180px;
    display: block;
    perspective: 1000px;
  }

  .image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    cursor: pointer;
  }

  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%; /* Círculo por defecto */
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: block;
  }

  .ig-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(188, 24, 136, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    opacity: 0;
    transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    color: white;
  }

  .ig-icon {
    transform: scale(0.5);
    transition: transform 0.4s ease;
  }

  /* Efecto Hover */
  .photo-link-animated:hover img {
    border-radius: 20px; /* Cambia a cuadrado redondeado */
    transform: scale(1.05);
    box-shadow: 0 15px 35px rgba(188, 24, 136, 0.2);
  }

  .photo-link-animated:hover .ig-overlay {
    border-radius: 20px;
    opacity: 1;
  }

  .photo-link-animated:hover .ig-icon {
    transform: scale(1.2);
  }

  @media (max-width: 600px) {
    .photo-flex-row {
      gap: 1rem;
    }
    .photo-link-animated {
      flex: 0 1 100px;
    }
  }
</style>
