---
const today = new Date();
---
<footer>
	<div class="footer-content">
		<p class="copyright">&copy; {today.getFullYear()} AFA Escola Ítaca. Tots els drets reservats.</p>
		<nav class="footer-nav">
			<a href="/legal">Avís Legal i Privacitat</a>
			<span class="separator">•</span>
			<a href="/contacte">Contacte</a>
		</nav>
	</div>
</footer>

<style>
	footer {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 1rem;
		background: #f0f8ff; /* Azul celeste extremadamente clarito */
		color: var(--text-main);
		text-align: center;
		box-sizing: border-box;
	}
	.footer-content {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.4rem;
	}
	.copyright {
		margin: 0;
		font-size: 0.9rem;
		opacity: 0.9;
		font-weight: 500;
	}
	.footer-nav {
		display: flex;
		justify-content: center;
		gap: 0.75rem;
		align-items: center;
	}
	.footer-nav a {
		font-size: 0.8rem;
		color: var(--text-light);
		text-decoration: none;
		transition: color 0.2s;
	}
	.footer-nav a:hover {
		color: var(--accent-dark);
		text-decoration: underline;
	}
	.separator {
		color: rgba(0, 0, 0, 0.2);
		font-size: 0.8rem;
	}
</style>
